{
	"name": "madr",
	"version": "1.0.4",
	"description": "Author MADR (Markdown Any Decision Records) documents from within your vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"typecheck:test": "tsc -noEmit -p tsconfig.test.json",
		"check:placeholders": "! grep -rnE \"Sample|MyPlugin|TODO\" src"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.1.1",
		"markdownlint": "^0.41.0",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.9",
		"yaml": "^2.9.0"
	}
}
